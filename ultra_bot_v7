import os
import math
import time
import uuid
import logging
from dataclasses import dataclass, field
from datetime import datetime, timedelta
from typing import Dict, List, Optional

import numpy as np
import pandas as pd
import pytz

from alpaca.trading.client import TradingClient
from alpaca.trading.requests import (
    GetAssetsRequest,
    MarketOrderRequest,
    GetOrdersRequest,
)
from alpaca.trading.enums import (
    AssetClass,
    AssetStatus,
    OrderSide,
    TimeInForce,
    QueryOrderStatus,
)
from alpaca.data.historical import StockHistoricalDataClient
from alpaca.data.requests import StockBarsRequest, StockLatestQuoteRequest
from alpaca.data.timeframe import TimeFrame


# =========================================
# CONFIG
# =========================================

@dataclass
class BotConfig:
    # Universe
    max_scan_symbols: int = 3000
    min_price: float = 2.0
    max_price: float = 80.0

    # Liquidity filters
    min_avg_volume: int = 500_000
    min_dollar_volume: float = 5_000_000
    max_spread_pct: float = 0.0035   # 0.35%

    # Timing
    bar_lookback_minutes: int = 120
    cooldown_minutes_after_entry: int = 15
    loop_sleep_seconds: int = 60
    market_timezone: str = "America/New_York"

    # Scoring
    top_candidates: int = 20
    final_pick_count: int = 5
    min_score_to_trade: float = 55.0

    # Risk
    max_open_positions: int = 5
    risk_per_trade_pct_of_equity: float = 0.005   # 0.5%
    max_position_notional_pct: float = 0.10       # 10% of equity max per position
    max_total_exposure_pct: float = 0.50          # 50% total exposure
    hard_stop_pct: float = 0.008                  # 0.8%
    take_profit_pct: float = 0.015                # 1.5%
    trailing_stop_pct: float = 0.007              # 0.7%

    # Safety
    daily_loss_limit_pct: float = 0.02            # 2%
    max_new_entries_per_cycle: int = 2
    cancel_open_orders_each_cycle: bool = False

    # Execution
    use_fractional_notional: bool = False
    default_order_notional: float = 0.0           # used only if use_fractional_notional=True


@dataclass
class PositionState:
    symbol: str
    entry_price: float
    qty: float
    high_since_entry: float
    entered_at: datetime
    stop_price: float
    take_profit_price: float
    trailing_stop_price: float
    client_order_id: str = field(default_factory=lambda: str(uuid.uuid4())[:18])


# =========================================
# BOT
# =========================================

class UltraBotV7:
    def __init__(self, config: BotConfig):
        api_key = os.getenv("APCA_API_KEY_ID", "").strip()
        api_secret = os.getenv("APCA_API_SECRET_KEY", "").strip()
        paper = os.getenv("APCA_PAPER", "true").strip().lower() == "true"

        if not api_key:
            raise ValueError("Missing APCA_API_KEY_ID environment variable.")
        if not api_secret:
            raise ValueError("Missing APCA_API_SECRET_KEY environment variable.")

        self.config = config
        self.paper = paper
        self.ny_tz = pytz.timezone(config.market_timezone)

        self.trading_client = TradingClient(api_key, api_secret, paper=paper)
        self.data_client = StockHistoricalDataClient(api_key, api_secret)

        self.positions_state: Dict[str, PositionState] = {}
        self.last_entry_time: Dict[str, datetime] = {}
        self.start_equity: Optional[float] = None
        self.daily_stop_triggered: bool = False

        logging.basicConfig(
            level=logging.INFO,
            format="%(asctime)s | %(levelname)s | %(message)s"
        )
        self.log = logging.getLogger("UltraBotV7")

    # =========================================
    # BASIC HELPERS
    # =========================================

    def now_ny(self) -> datetime:
        return datetime.now(self.ny_tz)

    def is_market_open(self) -> bool:
        try:
            clock = self.trading_client.get_clock()
            return bool(clock.is_open)
        except Exception as e:
            self.log.exception(f"Failed to get market clock: {e}")
            return False

    def get_account(self):
        return self.trading_client.get_account()

    def get_equity(self) -> float:
        return float(self.get_account().equity)

    def get_buying_power(self) -> float:
        account = self.get_account()
        try:
            return float(account.buying_power)
        except Exception:
            return float(account.cash)

    def get_open_positions(self):
        return self.trading_client.get_all_positions()

    def get_open_orders(self):
        req = GetOrdersRequest(status=QueryOrderStatus.OPEN)
        return self.trading_client.get_orders(filter=req)

    def sync_existing_positions(self):
        current_positions = self.get_open_positions()
        live_symbols = set()

        for pos in current_positions:
            symbol = pos.symbol
            live_symbols.add(symbol)

            qty = float(pos.qty)
            entry_price = float(pos.avg_entry_price)
            current_price = float(pos.current_price) if pos.current_price is not None else entry_price

            if symbol not in self.positions_state:
                self.positions_state[symbol] = PositionState(
                    symbol=symbol,
                    entry_price=entry_price,
                    qty=qty,
                    high_since_entry=max(entry_price, current_price),
                    entered_at=self.now_ny(),
                    stop_price=entry_price * (1 - self.config.hard_stop_pct),
                    take_profit_price=entry_price * (1 + self.config.take_profit_pct),
                    trailing_stop_price=current_price * (1 - self.config.trailing_stop_pct),
                )

        closed_symbols = [s for s in self.positions_state if s not in live_symbols]
        for s in closed_symbols:
            del self.positions_state[s]

    def check_daily_loss_limit(self):
        equity = self.get_equity()

        if self.start_equity is None:
            self.start_equity = equity
            self.log.info(f"Starting equity captured: {self.start_equity:.2f}")
            return

        drawdown = (self.start_equity - equity) / self.start_equity
        if drawdown >= self.config.daily_loss_limit_pct:
            self.daily_stop_triggered = True
            self.log.warning(
                f"Daily loss limit hit | Start={self.start_equity:.2f} | Current={equity:.2f} | Drawdown={drawdown:.2%}"
            )

    # =========================================
    # UNIVERSE / MARKET DATA
    # =========================================

    def fetch_tradable_universe(self) -> List[str]:
        self.log.info("Fetching tradable universe...")

        assets = self.trading_client.get_all_assets(
            GetAssetsRequest(
                asset_class=AssetClass.US_EQUITY,
                status=AssetStatus.ACTIVE
            )
        )

        symbols = []
        for a in assets:
            try:
                if getattr(a, "tradable", False):
                    symbol = a.symbol
                    if symbol and "." not in symbol and "/" not in symbol:
                        symbols.append(symbol)
            except Exception:
                continue

        symbols = symbols[:self.config.max_scan_symbols]
        self.log.info(f"Universe selected: {len(symbols)} symbols")
        return symbols

    def fetch_bars_df(self, symbols: List[str], minutes: int) -> pd.DataFrame:
        if not symbols:
            return pd.DataFrame()

        end_dt = self.now_ny()
        start_dt = end_dt - timedelta(minutes=minutes)

        req = StockBarsRequest(
            symbol_or_symbols=symbols,
            timeframe=TimeFrame.Minute,
            start=start_dt,
            end=end_dt,
            feed="iex" if self.paper else "sip"
        )

        bars = self.data_client.get_stock_bars(req)

        rows = []
        for symbol, symbol_bars in bars.data.items():
            for b in symbol_bars:
                rows.append({
                    "symbol": symbol,
                    "timestamp": b.timestamp,
                    "open": float(b.open),
                    "high": float(b.high),
                    "low": float(b.low),
                    "close": float(b.close),
                    "volume": int(b.volume)
                })

        df = pd.DataFrame(rows)
        if not df.empty:
            df.sort_values(["symbol", "timestamp"], inplace=True)

        return df

    def fetch_latest_quotes(self, symbols: List[str]) -> Dict[str, dict]:
        quotes = {}
        if not symbols:
            return quotes

        chunk_size = 200

        for i in range(0, len(symbols), chunk_size):
            chunk = symbols[i:i + chunk_size]

            req = StockLatestQuoteRequest(
                symbol_or_symbols=chunk,
                feed="iex" if self.paper else "sip"
            )

            q = self.data_client.get_stock_latest_quote(req)

            for sym, val in q.items():
                quotes[sym] = {
                    "bid": float(val.bid_price) if val.bid_price is not None else 0.0,
                    "ask": float(val.ask_price) if val.ask_price is not None else 0.0
                }

        return quotes

    # =========================================
    # SCORING
    # =========================================

    @staticmethod
    def safe_pct_change(a: float, b: float) -> float:
        if b == 0:
            return 0.0
        return (a - b) / b

    def score_symbols(self, bars_df: pd.DataFrame, latest_quotes: Dict[str, dict]) -> pd.DataFrame:
        if bars_df.empty:
            return pd.DataFrame()

        scored = []
        grouped = bars_df.groupby("symbol")

        for symbol, df in grouped:
            if len(df) < 30:
                continue

            close = df["close"].values
            high = df["high"].values
            low = df["low"].values
            volume = df["volume"].values

            last_price = float(close[-1])
            if last_price < self.config.min_price or last_price > self.config.max_price:
                continue

            avg_vol = int(np.mean(volume[-30:]))
            avg_dollar_vol = float(np.mean(close[-30:] * volume[-30:]))

            if avg_vol < self.config.min_avg_volume:
                continue
            if avg_dollar_vol < self.config.min_dollar_volume:
                continue

            q = latest_quotes.get(symbol, {})
            bid = q.get("bid", 0.0)
            ask = q.get("ask", 0.0)

            if bid <= 0 or ask <= 0 or ask < bid:
                continue

            spread_pct = (ask - bid) / last_price
            if spread_pct > self.config.max_spread_pct:
                continue

            ret_5 = self.safe_pct_change(close[-1], close[-6]) if len(close) >= 6 else 0.0
            ret_15 = self.safe_pct_change(close[-1], close[-16]) if len(close) >= 16 else 0.0
            intraday_range = (np.max(high[-15:]) - np.min(low[-15:])) / last_price

            vwap = np.sum(close[-30:] * volume[-30:]) / max(np.sum(volume[-30:]), 1)
            above_vwap = 1.0 if last_price > vwap else 0.0

            breakout_15 = 0.0
            if len(high) > 15:
                breakout_15 = 1.0 if last_price >= np.max(high[-15:-1]) else 0.0

            volume_spike = volume[-1] / max(np.mean(volume[-20:]), 1)

            score = (
                (ret_5 * 100 * 2.5) +
                (ret_15 * 100 * 2.0) +
                (intraday_range * 100 * 0.8) +
                (above_vwap * 8.0) +
                (breakout_15 * 12.0) +
                (min(volume_spike, 4.0) * 7.0) +
                ((1.0 - min(spread_pct / self.config.max_spread_pct, 1.0)) * 10.0)
            )

            scored.append({
                "symbol": symbol,
                "price": last_price,
                "avg_volume": avg_vol,
                "avg_dollar_volume": avg_dollar_vol,
                "spread_pct": spread_pct,
                "ret_5_pct": ret_5 * 100,
                "ret_15_pct": ret_15 * 100,
                "intraday_range_pct": intraday_range * 100,
                "vwap": vwap,
                "volume_spike": volume_spike,
                "score": score
            })

        out = pd.DataFrame(scored)
        if out.empty:
            return out

        out.sort_values("score", ascending=False, inplace=True)
        return out

    # =========================================
    # RISK / POSITION SIZE
    # =========================================

    def calc_position_size(self, price: float, equity: float) -> int:
        stop_distance = max(price * self.config.hard_stop_pct, 0.01)
        risk_amount = equity * self.config.risk_per_trade_pct_of_equity

        qty_by_risk = math.floor(risk_amount / stop_distance)
        max_position_value = equity * self.config.max_position_notional_pct
        qty_by_cap = math.floor(max_position_value / price)

        qty = max(0, min(qty_by_risk, qty_by_cap))
        return qty

    def current_total_exposure(self) -> float:
        total = 0.0
        for pos in self.get_open_positions():
            total += abs(float(pos.market_value))
        return total

    def can_open_new_position(self, symbol: str) -> bool:
        if self.daily_stop_triggered:
            return False

        self.sync_existing_positions()

        if symbol in self.positions_state:
            return False

        now = self.now_ny()
        last_t = self.last_entry_time.get(symbol)
        if last_t and (now - last_t) < timedelta(minutes=self.config.cooldown_minutes_after_entry):
            return False

        if len(self.positions_state) >= self.config.max_open_positions:
            return False

        equity = self.get_equity()
        exposure = self.current_total_exposure()
        if exposure >= (equity * self.config.max_total_exposure_pct):
            return False

        return True

    # =========================================
    # ORDERS
    # =========================================

    def submit_buy_order(self, symbol: str, price: float) -> bool:
        try:
            equity = self.get_equity()
            bp = self.get_buying_power()

            if self.config.use_fractional_notional and self.config.default_order_notional > 0:
                notional = min(self.config.default_order_notional, bp * 0.95)

                if notional < 25:
                    self.log.info(f"Skip {symbol}: not enough buying power for notional order.")
                    return False

                order = MarketOrderRequest(
                    symbol=symbol,
                    side=OrderSide.BUY,
                    time_in_force=TimeInForce.DAY,
                    notional=round(notional, 2),
                    client_order_id=str(uuid.uuid4())[:18]
                )

                self.trading_client.submit_order(order_data=order)
                qty_for_state = notional / price

            else:
                qty = self.calc_position_size(price, equity)
                qty_value = qty * price

                if qty < 1:
                    self.log.info(f"Skip {symbol}: calculated qty < 1.")
                    return False

                if qty_value > bp * 0.95:
                    self.log.info(f"Skip {symbol}: insufficient buying power.")
                    return False

                order = MarketOrderRequest(
                    symbol=symbol,
                    qty=qty,
                    side=OrderSide.BUY,
                    time_in_force=TimeInForce.DAY,
                    client_order_id=str(uuid.uuid4())[:18]
                )

                self.trading_client.submit_order(order_data=order)
                qty_for_state = float(qty)

            state = PositionState(
                symbol=symbol,
                entry_price=price,
                qty=float(qty_for_state),
                high_since_entry=price,
                entered_at=self.now_ny(),
                stop_price=price * (1 - self.config.hard_stop_pct),
                take_profit_price=price * (1 + self.config.take_profit_pct),
                trailing_stop_price=price * (1 - self.config.trailing_stop_pct),
            )

            self.positions_state[symbol] = state
            self.last_entry_time[symbol] = self.now_ny()

            self.log.info(f"BUY submitted | {symbol} | est_price={price:.2f} | qty={qty_for_state}")
            return True

        except Exception as e:
            self.log.exception(f"BUY failed for {symbol}: {e}")
            return False

    def submit_sell_order(self, symbol: str, qty: float, reason: str):
        try:
            order_qty = qty

            # لو الكمية عدد صحيح نخليها int
            if float(qty).is_integer():
                order_qty = int(qty)

            order = MarketOrderRequest(
                symbol=symbol,
                qty=order_qty,
                side=OrderSide.SELL,
                time_in_force=TimeInForce.DAY,
                client_order_id=str(uuid.uuid4())[:18]
            )

            self.trading_client.submit_order(order_data=order)
            self.log.info(f"SELL submitted | {symbol} | qty={order_qty} | reason={reason}")

        except Exception as e:
            self.log.exception(f"SELL failed for {symbol}: {e}")

    def cancel_all_open_orders(self):
        try:
            self.trading_client.cancel_orders()
            self.log.info("Cancelled all open orders.")
        except Exception as e:
            self.log.exception(f"Cancel open orders failed: {e}")

    # =========================================
    # POSITION MANAGEMENT
    # =========================================

    def manage_positions(self, latest_quotes: Dict[str, dict]):
        self.sync_existing_positions()

        for symbol, state in list(self.positions_state.items()):
            q = latest_quotes.get(symbol, {})
            bid = q.get("bid", 0.0)
            ask = q.get("ask", 0.0)

            if bid <= 0 and ask <= 0:
                continue

            current_price = bid if bid > 0 else ask

            if current_price > state.high_since_entry:
                state.high_since_entry = current_price

            new_trailing = state.high_since_entry * (1 - self.config.trailing_stop_pct)
            if new_trailing > state.trailing_stop_price:
                state.trailing_stop_price = new_trailing

            effective_stop = max(state.stop_price, state.trailing_stop_price)

            if current_price <= effective_stop:
                self.submit_sell_order(symbol, state.qty, f"stop_or_trailing_hit @ {current_price:.2f}")
                continue

            if current_price >= state.take_profit_price:
                self.submit_sell_order(symbol, state.qty, f"take_profit_hit @ {current_price:.2f}")
                continue

    def close_all_positions(self):
        self.sync_existing_positions()
        for symbol, state in list(self.positions_state.items()):
            self.submit_sell_order(symbol, state.qty, "daily_stop_or_shutdown")

    # =========================================
    # ENTRY LOGIC
    # =========================================

    def select_trade_candidates(self, scored_df: pd.DataFrame) -> pd.DataFrame:
        if scored_df.empty:
            return scored_df

        held = set(self.positions_state.keys())
        df = scored_df[~scored_df["symbol"].isin(held)].copy()
        df = df[df["score"] >= self.config.min_score_to_trade]
        df = df.head(self.config.top_candidates).copy()
        return df.head(self.config.final_pick_count)

    def try_new_entries(self, candidate_df: pd.DataFrame):
        if candidate_df.empty:
            self.log.info("No valid entry candidates this cycle.")
            return

        entries_done = 0

        for _, row in candidate_df.iterrows():
            symbol = row["symbol"]
            price = float(row["price"])

            if entries_done >= self.config.max_new_entries_per_cycle:
                break

            if not self.can_open_new_position(symbol):
                continue

            ok = self.submit_buy_order(symbol, price)
            if ok:
                entries_done += 1

    # =========================================
    # MAIN CYCLE
    # =========================================

    def run_cycle(self, symbols: List[str]):
        self.check_daily_loss_limit()

        if self.daily_stop_triggered:
            self.log.warning("Daily loss protection active. Closing positions.")
            self.close_all_positions()
            return

        if self.config.cancel_open_orders_each_cycle:
            self.cancel_all_open_orders()

        bars_df = self.fetch_bars_df(symbols, self.config.bar_lookback_minutes)
        if bars_df.empty:
            self.log.warning("No bars returned this cycle.")
            return

        unique_symbols = list(bars_df["symbol"].unique())
        quotes = self.fetch_latest_quotes(unique_symbols)

        self.manage_positions(quotes)

        scored_df = self.score_symbols(bars_df, quotes)
        if scored_df.empty:
            self.log.info("No scored symbols this cycle.")
            return

        self.log.info("Top scored symbols:")
        self.log.info("\n" + str(scored_df.head(10)[["symbol", "price", "score", "spread_pct", "volume_spike"]]))

        candidates = self.select_trade_candidates(scored_df)
        self.try_new_entries(candidates)

    # =========================================
    # RUN
    # =========================================

    def run(self):
        self.log.info(f"Bot starting | Paper={self.paper}")

        symbols = self.fetch_tradable_universe()
        if not symbols:
            raise RuntimeError("No tradable symbols found.")

        while True:
            try:
                if self.is_market_open():
                    self.run_cycle(symbols)
                else:
                    self.log.info("Market is closed. Sleeping...")

                time.sleep(self.config.loop_sleep_seconds)

            except KeyboardInterrupt:
                self.log.warning("Bot stopped by user.")
                break

            except Exception as e:
                self.log.exception(f"Main loop error: {e}")
                time.sleep(10)


# =========================================
# ENTRY POINT
# =========================================

if __name__ == "__main__":
    config = BotConfig(
        max_scan_symbols=3000,
        max_open_positions=5,
        final_pick_count=5,
        top_candidates=20,
        loop_sleep_seconds=60,
        bar_lookback_minutes=120,
        min_price=2.0,
        max_price=80.0,
        min_avg_volume=500_000,
        min_dollar_volume=5_000_000,
        max_spread_pct=0.0035,
        risk_per_trade_pct_of_equity=0.005,
        hard_stop_pct=0.008,
        take_profit_pct=0.015,
        trailing_stop_pct=0.007,
        daily_loss_limit_pct=0.02,
        cooldown_minutes_after_entry=15,
        max_new_entries_per_cycle=2,
    )

    bot = UltraBotV7(config)
    bot.run()